# pyenv
#   For a library or app, you might want to share your .python-version.
#   Comment under the line if you want to include it.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different platforms or python versions,
#   feel free to ignore Pipfile.lock.
# Pipfile.lock

# poetry
#   Similar to Pipenv, poetry.lock contains specific versions of dependencies
#   poetry.lock

# pdm
#   Similar to Pipenv, pdm.lock contains specific versions of dependencies
#   pdm.lock
#   pdm build stage
.pdm-build/

# PEP 582; used by e.g. github.com/lincolnloop/layman and pdm
